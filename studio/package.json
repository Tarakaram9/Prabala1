{
  "name": "prabala-studio",
  "version": "0.1.0",
  "description": "Prabala Test Studio – Visual Electron IDE for Prabala automation framework",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"npx ts-node ../packages/studio-server/src/index.ts\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:web": "concurrently -k \"npx ts-node ../packages/studio-server/src/index.ts\" \"VITE_TARGET=web vite\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:web": "VITE_TARGET=web vite build",
    "preview": "electron .",
    "pack": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --publish=always"
  },
  "dependencies": {
    "@prabala/core": "*",
    "@prabala/driver-web": "*",
    "@xyflow/react": "^12.0.0",
    "axios": "^1.6.8",
    "electron": "^30.0.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.378.0",
    "openai": "^6.32.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "rimraf": "^5.0.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "io.prabala.studio",
    "productName": "Prabala",
    "icon": "src/assets/icon",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "src/assets/icons/mac/icon.icns",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "win": {
      "icon": "src/assets/icons/win/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "src/assets/icons/png",
      "target": "AppImage"
    },
    "publish": {
      "provider": "generic",
      "url": "https://stiototportaldev.blob.core.windows.net/releases/"
    }
  },
  "license": "Apache-2.0"
}
