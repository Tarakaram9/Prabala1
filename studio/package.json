{
  "name": "prabala-studio",
  "version": "0.1.0",
  "description": "Prabala Test Studio – Visual Electron IDE for Prabala automation framework",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "preview": "electron .",
    "pack": "npm run build && electron-builder"
  },
  "dependencies": {
    "@prabala/core": "*",
    "@prabala/driver-web": "*",
    "@xyflow/react": "^12.0.0",
    "axios": "^1.6.8",
    "electron": "^30.0.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.378.0",
    "openai": "^6.32.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "rimraf": "^5.0.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "io.prabala.studio",
    "productName": "Prabala Studio",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "license": "Apache-2.0"
}
